---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllPosts, getPostBySlug } from '../../lib/notion';

export async function getStaticPaths() {
  // 公開予定・公開済みの記事すべてに対してビルド時にページを生成
  const posts = await getAllPosts(true);
  return posts
    .filter((p) => p.slug && (p.status === '公開済み' || p.status === '公開予定'))
    .map((post) => ({
      params: { slug: post.slug },
    }));
}

const { slug } = Astro.params;
const result = await getPostBySlug(slug as string);

if (!result) {
  return Astro.redirect('/blog');
}

const { post, html } = result;

// 同じカテゴリ内の前後の記事（公開済みのみ）
// 公開日が古い順に並べ、現在の記事の前後を探す
const allPublished = await getAllPosts(false);
const sameCategoryAsc = allPublished
  .filter((p) => p.category === post.category && p.slug && p.slug !== post.slug)
  .reverse(); // getAllPosts は降順なので昇順に

let prev: typeof post | null = null;
let next: typeof post | null = null;
if (post.category && post.date) {
  for (const p of sameCategoryAsc) {
    if (p.date < post.date) prev = p; // 古い側 → 上書きで最新の "古い記事" が残る
    else if (p.date > post.date && !next) next = p; // 新しい側 → 最初に見つかったもの
  }
}

const formattedDate = post.date
  ? new Date(post.date).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<BaseLayout
  title={`${post.title}｜水素のお兄さん とびchan.`}
  description={post.description}
  image={post.heroImage || '/og-default.jpg'}
>
  <Header />

  <div class="container mx-auto px-4 py-8 sm:py-12">
    <div class="mx-auto max-w-3xl xl:max-w-[68rem] xl:grid xl:grid-cols-[minmax(0,_48rem)_16rem] xl:gap-8">

    <article>
    {/* ヘッダー部 */}
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        {post.category && (
          <span class="inline-block text-xs font-bold px-3 py-1 rounded-full bg-blue-100 text-blue-700">
            {post.category}
          </span>
        )}
        {post.status === '公開予定' && (
          <span class="inline-block text-xs font-bold px-3 py-1 rounded-full bg-yellow-100 text-yellow-700">
            プレビュー
          </span>
        )}
        {formattedDate && (
          <span class="text-sm text-gray-500">{formattedDate}</span>
        )}
      </div>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-800 leading-tight mb-3">
        {post.title}
      </h1>
      {post.description && (
        <p class="text-base text-gray-600 leading-relaxed">
          {post.description}
        </p>
      )}
    </header>

    {/* アイキャッチ画像 */}
    {post.heroImage && (
      <img
        src={post.heroImage}
        alt={post.title}
        class="w-full aspect-video object-cover rounded-2xl mb-8 shadow-lg"
      />
    )}

    {/* 本文 */}
    <div
      class="prose prose-base sm:prose-lg max-w-none prose-headings:text-gray-800 prose-a:text-blue-600 prose-strong:text-gray-800 prose-img:rounded-xl prose-img:shadow-md article-body"
      set:html={html}
    />

    {/* タグ */}
    {post.tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-gray-200">
        <div class="text-xs text-gray-500 mb-2">タグ</div>
        <div class="flex flex-wrap gap-2">
          {post.tags.map((tag) => (
            <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 text-gray-700">
              # {tag}
            </span>
          ))}
        </div>
      </div>
    )}

    {/* 関連動画リンク */}
    {post.youtubeUrl && (
      <div class="mt-8 p-5 bg-gray-50 rounded-xl border border-gray-200">
        <p class="text-sm font-bold text-gray-700 mb-2">📺 関連動画</p>
        <div class="space-y-1.5 text-sm">
          <div>
            <a href={post.youtubeUrl} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">
              元動画を YouTube で見る →
            </a>
          </div>
        </div>
      </div>
    )}

    {/* 記事末尾：前後の記事ナビ（全画面サイズで表示） */}
    {(prev || next) && (
      <nav class="mt-10 grid grid-cols-2 gap-3 sm:gap-4" aria-label="同じカテゴリの前後の記事">
        {prev ? (
          <a
            href={`/blog/${prev.slug}`}
            class="group block p-4 sm:p-5 bg-white rounded-xl shadow-sm hover:shadow-md border border-gray-200 hover:border-blue-300 transition-all"
          >
            <div class="text-xs text-gray-500 mb-1.5 group-hover:text-blue-600">← 前の記事</div>
            <div class="text-sm font-medium text-gray-800 leading-snug line-clamp-3">{prev.title}</div>
          </a>
        ) : (
          <div></div>
        )}
        {next ? (
          <a
            href={`/blog/${next.slug}`}
            class="group block p-4 sm:p-5 bg-white rounded-xl shadow-sm hover:shadow-md border border-gray-200 hover:border-blue-300 transition-all text-right"
          >
            <div class="text-xs text-gray-500 mb-1.5 group-hover:text-blue-600">次の記事 →</div>
            <div class="text-sm font-medium text-gray-800 leading-snug line-clamp-3">{next.title}</div>
          </a>
        ) : (
          <div></div>
        )}
      </nav>
    )}

    {/* 一覧に戻る */}
    <div class="mt-12 pt-8 border-t border-gray-200 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-full font-semibold text-sm sm:text-base hover:bg-blue-700 transition-all transform hover:-translate-y-0.5 shadow-lg hover:shadow-xl"
      >
        ← ブログ一覧に戻る
      </a>
    </div>
    </article>

    {/* デスクトップ用：固定サイドバー */}
    {(prev || next) && (
      <aside class="hidden xl:block" aria-label="同じカテゴリの前後の記事">
        <div class="sticky top-24 space-y-3">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-1 mb-2">
            📚 同シリーズ
          </h3>
          {prev && (
            <a
              href={`/blog/${prev.slug}`}
              class="block p-4 bg-white rounded-xl shadow-sm hover:shadow-md border border-gray-200 transition-all"
            >
              <div class="text-xs text-gray-500 mb-1.5">← 前の記事</div>
              <div class="text-sm font-medium text-gray-800 leading-snug">{prev.title}</div>
            </a>
          )}
          {next && (
            <a
              href={`/blog/${next.slug}`}
              class="block p-4 bg-white rounded-xl shadow-sm hover:shadow-md border border-gray-200 transition-all"
            >
              <div class="text-xs text-gray-500 mb-1.5 text-right">次の記事 →</div>
              <div class="text-sm font-medium text-gray-800 leading-snug">{next.title}</div>
            </a>
          )}
        </div>
      </aside>
    )}

    </div>
  </div>

  <Footer />
</BaseLayout>

<style is:global>
  /* YouTube動画埋め込みの16:9レスポンシブスタイル */
  .article-body .video-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    margin: 1.5rem 0;
    border-radius: 0.75rem;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.2);
  }

  .article-body .video-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 0.75rem;
  }
</style>
