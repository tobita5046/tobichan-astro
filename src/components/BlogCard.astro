---
import type { BlogPost } from '../lib/notion';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const categoryColors: Record<string, string> = {
  '突撃！水素テック': 'bg-red-100 text-red-700',
  '社会人のための水素講座': 'bg-blue-100 text-blue-700',
  '毎日水素ニュース': 'bg-green-100 text-green-700',
  'イベントレポート': 'bg-purple-100 text-purple-700',
  'その他': 'bg-gray-100 text-gray-700',
};

const categoryClass = categoryColors[post.category] || 'bg-gray-100 text-gray-700';

const formattedDate = post.date
  ? new Date(post.date).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<a
  href={`/blog/${post.slug}`}
  class="group block bg-white rounded-xl shadow-md hover:shadow-2xl overflow-hidden transition-all duration-300 transform hover:-translate-y-1"
>
  {post.heroImage && (
    <div class="aspect-video bg-gray-200 overflow-hidden">
      <img
        src={post.heroImage}
        alt={post.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-4 sm:p-5">
    <div class="flex items-center gap-2 mb-2 flex-wrap">
      {post.category && (
        <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full ${categoryClass}`}>
          {post.category}
        </span>
      )}
      {formattedDate && (
        <span class="text-xs text-gray-500">{formattedDate}</span>
      )}
    </div>
    <h2 class="font-bold text-base sm:text-lg leading-tight text-gray-800 group-hover:text-blue-600 transition-colors mb-2">
      {post.title}
    </h2>
    {post.description && (
      <p class="text-sm text-gray-600 leading-relaxed line-clamp-3">
        {post.description}
      </p>
    )}
  </div>
</a>
